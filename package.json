{
  "name": "agency-os",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "bun --filter @agency-os/api dev",
    "dev:mobile": "bun --filter @agency-os/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "bun --filter @agency-os/api db:generate",
    "db:migrate": "bun --filter @agency-os/api db:migrate",
    "db:studio": "bun --filter @agency-os/api db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.0.10",
    "@types/react-dom": "~19.0.4"
  },
  "trustedDependencies": [
    "@clerk/shared",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ]
}
