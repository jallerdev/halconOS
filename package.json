{
  "name": "halcon-os",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --filter @halcon-os/api dev",
    "build": "pnpm --filter @halcon-os/api build",
    "lint": "pnpm --filter @halcon-os/api lint",
    "typecheck": "pnpm --filter @halcon-os/api typecheck",
    "db:generate": "pnpm --filter @halcon-os/api db:generate",
    "db:migrate": "pnpm --filter @halcon-os/api db:migrate",
    "db:studio": "pnpm --filter @halcon-os/api db:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.0.10",
      "@types/react-dom": "~19.0.4"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
