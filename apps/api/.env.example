# Base de datos (Postgres). Las tablas viven en el esquema agency_os.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Clerk (auth). Si se omite, en dev se usa DEV_BYPASS_USER_ID.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
DEV_BYPASS_USER_ID="local"

# IA (Gemini) — opcional.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# CORS para clientes web/Expo (coma-separados).
ALLOWED_ORIGINS=""

# Leads entrantes (/api/inbound/lead): las API keys se generan por organización
# desde el dashboard (Ajustes) y se guardan hasheadas en la DB. No hay vars de env.

# Google OAuth (Calendar + Meet). Si se omiten, la conexión con Google queda deshabilitada.
# 1. Crear proyecto en https://console.cloud.google.com/, habilitar Google Calendar API.
# 2. OAuth consent screen + credenciales tipo "Web application".
# 3. Authorized redirect URI: la misma URL absoluta que GOOGLE_OAUTH_REDIRECT_URI.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/auth/callback"

# Clave AES-256-GCM para cifrar refresh tokens de Google. 32 bytes en hex (64 chars).
# Generar: openssl rand -hex 32
# Cambiar esta clave invalida todos los refresh tokens guardados (los usuarios reconectan).
ENCRYPTION_KEY=""
