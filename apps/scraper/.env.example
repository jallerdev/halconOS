# Variables requeridas por el scraper.
# Para desarrollo local, copia este archivo a `.env` y rellena.

# Key del LLM. Es la MISMA que usa HalcónOS para Gemini (un solo proyecto Google Cloud).
GEMINI_API_KEY=

# Secret compartido con HalcónOS. Genera con: openssl rand -hex 32
# Debe coincidir EXACTAMENTE con SCRAPER_SHARED_SECRET en apps/api/.env
SCRAPER_SHARED_SECRET=

# CORS (opcional). En producción puede dejarse vacío — el servicio se llama desde el
# backend de HalcónOS, no desde navegadores.
ALLOWED_ORIGINS=
